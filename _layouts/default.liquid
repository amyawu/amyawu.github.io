<!doctype html>
<html lang="{{ site.lang }}">
  <!-- Head -->
  <head>
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}
    {% include head.liquid %}
  </head>

  <!-- Body -->
  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
    <!-- Header -->
    {% include header.liquid %}

    <!-- Content -->
    <div class="container mt-5" role="main">
      {% if page.toc and page.toc.sidebar %}
        {% if page.toc.sidebar == 'right' %}
          <div class="row">
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
          </div>
        {% else %}
          <div class="row">
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
          </div>
        {% endif %}
      {% else %}
        {{ content }}
      {% endif %}
    </div>

    <!-- Footer -->
    {% include footer.liquid %}

    <div id="bunny-cutscene" class="bunny-cutscene-overlay bunny-cutscene-hidden" aria-hidden="true">
      <section class="bunny-cutscene-panel" role="dialog" aria-modal="true" aria-labelledby="bunny-cutscene-title">
        <h2 id="bunny-cutscene-title" class="bunny-cutscene-title">BEFORE YOU PROCEED, CHOOSE YOUR BUNNY COMPANION:</h2>
        <div class="bunny-cutscene-grid">
          <button
            type="button"
            class="bunny-cutscene-card"
            data-bunny-name="Nora"
            data-bunny-type="Normal"
            data-bunny-emoji="🐇"
            aria-label="Select Nora companion"
          >
            <span class="bunny-cutscene-card-name">Nora</span>
            <span
              class="bunny-cutscene-card-sprite is-animated"
              aria-hidden="true"
              style="--bunny-sprite-url: url('{{ '/assets/sprites/nora_idle.gif' | relative_url }}');"
            ></span>
            <span class="bunny-cutscene-card-copy">
              Normal type bunny or is it? Nora enjoys working with everyone and to advocate for deeper impact.
            </span>
            <span class="bunny-cutscene-card-tip">Pick Nora if you are into everything!</span>
          </button>
          <button
            type="button"
            class="bunny-cutscene-card"
            data-bunny-name="Sunny"
            data-bunny-type="Light"
            data-bunny-emoji="🌟"
            aria-label="Select Sunny companion"
          >
            <span class="bunny-cutscene-card-name">Sunny</span>
            <span
              class="bunny-cutscene-card-sprite is-animated"
              aria-hidden="true"
              style="--bunny-sprite-url: url('{{ '/assets/sprites/sunny_idle.gif' | relative_url }}');"
            ></span>
            <span class="bunny-cutscene-card-copy">
              Light type bunny. She's a big fan of anything science. Particularly focuses on
              computational design especially establishing CAD and machine learning models. Loves to collaborate with Pyro!
            </span>
            <span class="bunny-cutscene-card-tip">Pick Sunny if you are into AI for science!</span>
          </button>
          <button
            type="button"
            class="bunny-cutscene-card"
            data-bunny-name="Pyro"
            data-bunny-type="Fire"
            data-bunny-emoji="🔥"
            aria-label="Select Pyro companion"
          >
            <span class="bunny-cutscene-card-name">Pyro</span>
            <span
              class="bunny-cutscene-card-sprite is-animated"
              aria-hidden="true"
              style="--bunny-sprite-url: url('{{ '/assets/sprites/pyro_idle.gif' | relative_url }}');"
            ></span>
            <span class="bunny-cutscene-card-copy">
              Fire type bunny. He is a delight to be around! Often concentrates on assessing artificial intelligence, especially language
              models. Usually seen around Sunny most days.
            </span>
            <span class="bunny-cutscene-card-tip">Pick Pyro if you are into data vis!</span>
          </button>
          <button
            type="button"
            class="bunny-cutscene-card"
            data-bunny-name="Aqua"
            data-bunny-type="Water"
            data-bunny-emoji="💧"
            aria-label="Select Aqua companion"
          >
            <span class="bunny-cutscene-card-name">Aqua</span>
            <span
              class="bunny-cutscene-card-sprite is-animated"
              aria-hidden="true"
              style="--bunny-sprite-url: url('{{ '/assets/sprites/aqua_idle.gif' | relative_url }}');"
            ></span>
            <span class="bunny-cutscene-card-copy">
              Water type bunny. They love to study how humans work! Their work centers on thematic analysis and
              qualitative coding. Nora is their typical go-to.
            </span>
            <span class="bunny-cutscene-card-tip">Pick Aqua if you are into mixed method!</span>
          </button>
        </div>
        <button type="button" id="bunny-cutscene-skip" class="bunny-cutscene-skip">Skip</button>
      </section>
    </div>

    <div id="bunny-companion-hud" class="bunny-companion-hud bunny-cutscene-hidden" aria-live="polite"></div>

    <!-- JavaScripts -->
    {% include scripts.liquid %}
  </body>
</html>
